{
  "name": "rightnow-fitness-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run start:dev",
    "dev:rag": "python rag-service/main.py",
    "db:up": "docker compose -f backend/docker-compose.yml up -d",
    "db:down": "docker compose -f backend/docker-compose.yml down",
    "db:logs": "docker compose -f backend/docker-compose.yml logs -f postgres",
    "db:push": "npm --workspace backend run prisma:push",
    "db:seed": "npm --workspace backend run prisma:seed",
    "db:init": "npm run db:push && npm run db:seed",
    "build:frontend": "npm --workspace frontend run build",
    "build:backend": "npm --workspace backend run build",
    "install:all": "npm install"
  }
}
